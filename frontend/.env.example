# Copy to .env.local and edit. .env* is gitignored.

# Dev proxy target for /api/* — leave unset for native dev (http://127.0.0.1:8000).
# Compose sets this to http://backend:8000 so the container can reach the backend.
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# Only needed for non-proxied builds (e.g. preview, production).
VITE_API_BASE=
