# Copy to .env and edit. .env is gitignored.
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave unset to use the local sqlite file. Compose sets this to point at the
# postgres service.
# DATABASE_URL=postgres://rlw:rlw@postgres:5432/rlw_dev

# Anthropic SDK. Required by `manage.py ingest_document` and
# `manage.py generate_briefing`. Without this key, both commands fail loudly.
ANTHROPIC_API_KEY=
# Optional model overrides. Defaults: sonnet-4-6 for briefings + ingest propose,
# opus-4-7 for the adversarial audit pass.
# ANTHROPIC_BRIEFING_MODEL=claude-sonnet-4-6
# ANTHROPIC_INGEST_MODEL=claude-sonnet-4-6
# ANTHROPIC_AUDIT_MODEL=claude-opus-4-7

# Briefing + ingest guardrails.
# BRIEFING_DAILY_CAP_PER_USER=10
# INGEST_MONTHLY_BUDGET_USD=30.0
