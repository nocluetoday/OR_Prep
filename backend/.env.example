# Copy to .env and edit. .env is gitignored.
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave unset to use the local sqlite file. Compose sets this to point at the
# postgres service.
# DATABASE_URL=postgres://rlw:rlw@postgres:5432/rlw_dev

# --- LLM providers ------------------------------------------------------------
#
# Each pipeline stage picks its own provider so you can mix backends. Default
# is "anthropic" for all four stages; set any of these to "openai", "lmstudio",
# or "openrouter" to swap. The corresponding API key + base URL for that
# provider must be set below.
#
# LLM_BRIEFING_PROVIDER=anthropic
# LLM_INGEST_PROPOSE_PROVIDER=anthropic
# LLM_INGEST_AUDIT_PROVIDER=anthropic
# LLM_INGEST_COMPOSE_PROVIDER=anthropic
#
# Model names per stage (defaults shown).
# LLM_BRIEFING_MODEL=claude-sonnet-4-6
# LLM_INGEST_PROPOSE_MODEL=claude-sonnet-4-6
# LLM_INGEST_AUDIT_MODEL=claude-opus-4-7
# LLM_INGEST_COMPOSE_MODEL=claude-sonnet-4-6

# Anthropic (required when any LLM_*_PROVIDER=anthropic).
ANTHROPIC_API_KEY=

# OpenAI (required when any LLM_*_PROVIDER=openai).
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# LM Studio (local, OpenAI-compatible). The API key is a sentinel — LM Studio
# accepts any non-empty string. Override base URL if your server is on a
# different port. Briefing tool-use reliability depends on the loaded model;
# many local models do not support tools well.
# LMSTUDIO_API_KEY=lm-studio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# OpenRouter (required when any LLM_*_PROVIDER=openrouter).
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Briefing + ingest guardrails.
# BRIEFING_DAILY_CAP_PER_USER=10
# INGEST_MONTHLY_BUDGET_USD=30.0
