# Copy to docker/.env and edit before `docker compose up`. .env is gitignored.

# Postgres credentials for the dev container. Internal-only — postgres is NOT
# exposed to the host. Override if you want to point at an external DB.
POSTGRES_USER=rlw
POSTGRES_PASSWORD=rlw
POSTGRES_DB=rlw_dev

# Django secret. Dev default is intentionally insecure; rotate for any shared use.
DJANGO_SECRET_KEY=dev-insecure-change-me
